    "@sendgrid/mail": "8.1.6",
    "cross-env": "10.1.0",
    "firebase": "12.14.0",
    "firebase-admin": "14.0.0",
    "framer-motion": "12.40.0",
    "grommet": "2.55.0",
    "hamburger-react": "2.5.2",
    "js-file-download": "0.4.12",
    "lodash": "4.18.1",
    "next": "16.2.9",
    "next-seo": "7.2.0",
    "next-sitemap": "4.2.3",
    "nookies": "2.5.2",
    "polished": "4.3.1",
