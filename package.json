{
  "name": "pila-app",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "dev:mock": "cp .env.mock .env.local && next dev",
    "build": "next build",
    "build:mock": "cp .env.mock .env.local && next build",
    "postbuild": "next-sitemap",
    "start": "next start",
    "slicemachine": "start-slicemachine --port 9999",
    "storybook": "storybook dev -p 8888",
    "build-storybook": "storybook build",
    "test": "jest",
    "lint": "eslint \"./**/*.{tsx,ts}\"",
    "tsc": "tsc --noEmit",
    "checklist": "concurrently --kill-others-on-fail \"yarn lint\" \"yarn tsc\" \"yarn test\"",
    "analyze": "ANALYZE=true yarn build"
  },
  "dependencies": {
    "@next/bundle-analyzer": "16.2.9",
